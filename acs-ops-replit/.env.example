DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_ZOHO_FORM_EMBED_URL=

# Website quote form email notifications.
# For Zoho Mail SMTP, use your Zoho email address and a Zoho app password/SMTP password.
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@yourdomain.com"
SMTP_PASS="your-zoho-mail-app-password"
QUOTE_NOTIFICATION_FROM="your-email@yourdomain.com"
QUOTE_NOTIFICATION_EMAIL="your-email@yourdomain.com"

# Optional: when the new app is ready, set this to forward website leads there too.
WEBSITE_LEAD_WEBHOOK_URL=
WEBSITE_LEAD_WEBHOOK_SECRET=
