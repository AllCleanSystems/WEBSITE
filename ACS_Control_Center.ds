				fsm_contact_id as "FSM Contact ID"
				sync_status as "Sync Status"
				sync_error as "Sync Error"
				last_sync_source as "Last Sync Source"
				last_sync_time as "Last Sync Time"
			)
			options
			(
	 			display field = sync_status
	 		)
		}
		list quote_line_items_Report
		{
			displayName = "All Quote Line Items"
			show all rows from quote_line_items    
			(
				quote as "Quote"
				line_description as "Line Description"
				quantity as "Quantity"
				unit_price as "Unit Price"
				(
					display = total,average,min,max	
				)
				tax_amount as "Tax Amount"
				(
					display = total,average,min,max	
				)
				line_total as "Line Total"
				(
					display = total,average,min,max	
				)
				optional_item as "Optional Item"
				selected_by_customer as "Selected By Customer"
				sort_order as "Sort Order"
			)
		}
		list system_counters_Report
		{
			displayName = "All System Counters"
			show all rows from system_counters    
			(
				counter_name as "Counter Name"
				prefix1 as "Prefix"
				next_number as "Next Number"
				pad_length as "Pad Length"
				active as "Active"
			)
		}
		list expenses_Report
		{
			displayName = "All Expenses"
			show all rows from expenses    
			(
				expense_name as "Expense Name"
				vendor as "Vendor"
				category as "Category"
				amount as "Amount"
				(
					display = total,average,min,max	
				)
				date_1 as "Date"
				receipt as "Receipt"
				related_work_order as "Related Work Order"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (category == "Equipment")
				fields = [category]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (category == "Other")
				fields = [category]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (category == "Travel")
				fields = [category]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban expenses_by_category
		{
			displayName = "Categories"
			show all rows from expenses    
			(
				expense_name as "Expense Name"
				vendor as "Vendor"
				category as "Category"
				amount as "Amount"
				(
					display = total,average,min,max	
				)
				date_1 as "Date"
				receipt as "Receipt"
				related_work_order as "Related Work Order"
			)
			options
			(
	 			display field = category
	 		)
		}
		list technicians_Report
		{
			displayName = "All Technicians"
			show all rows from technicians    
			(
				tech_name  as "Tech Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				phone as "Phone"
				role as "Role"
				clock_status as "Clock Status"
				notes as "Notes"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (role == "Other")
				fields = [role]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (role == "Supervisor")
				fields = [role]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (role == "Technician")
				fields = [role]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban technicians_by_role
		{
			displayName = "Roles"
			show all rows from technicians    
			(
				tech_name  as "Tech Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				phone as "Phone"
				role as "Role"
				clock_status as "Clock Status"
				notes as "Notes"
			)
			options
			(
	 			display field = role
	 		)
		}
	}
