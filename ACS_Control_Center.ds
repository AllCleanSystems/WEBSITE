		 functions
		 {
			 Deluge
			 {
				 map Functioncreatingaiagent()
                 {
                 	return Map();
                 }
			 }
		 }


		workflow
		{
		form
		{
			urgency_notification as "Urgency Notification"
			{
				type =  form
				form = service_requests

				record event = on add

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.urgency == "High")
										{
											sendmail
											[
												from :zoho.adminuserid
												to :zoho.loginuserid
												subject :"High Urgency Service Request Created"
												message :"A new service request with high urgency has been created. Request Summary: " + input.request_summary
												content type :HTML
											]
										}
						)
					}
				}

			}
			service_request_validation as "Service Request Validation"
			{
				type =  form
				form = service_requests

				record event = on add or edit

				on validate
				{
					actions 
					{
						custom deluge script
						(
											if(input.request_summary.isNull() || input.request_summary.isBlank())
										{
											alert(request_summary,"Request Summary cannot be empty");
											cancel submit;
										}
										if(input.status.isNull() || input.status.isBlank())
										{
											alert(status,"Status must be selected");
											cancel submit;
										}
										if(input.service_type.isNull() || input.service_type.isBlank())
										{
											alert(service_type,"Service Type must be selected");
											cancel submit;
										}
										if(input.urgency.isNull() || input.urgency.isBlank())
										{
											alert(urgency,"Urgency must be selected");
											cancel submit;
										}
										if(input.customer.isNull() || input.customer.isEmpty())
										{
											alert(customer,"Customer must be selected");
											cancel submit;
										}
						)
					}
				}

			}
		}

		schedule
		{
			monthly_financial_summary as "Monthly Financial Summary"
			{
				type =  schedule
					status = inactive
				start = "2024-05-26 15:53:12"
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						subjectText = "Monthly Financial Summary";
										messageBody = "<p>Dear Management,</p><p>Please find the monthly financial summary attached.</p>";
										sendmail
										[
											from :zoho.adminuserid
											to :zoho.adminuserid
											subject :subjectText
											message :messageBody
											content type :HTML
										]
					)
					}
				}
			}
			invoice_due_reminder as "Invoice Due Reminder"
			{
				type =  schedule
				form = invoices
					status = inactive
				start = last_sync_time
				time zone = "Asia/Kolkata"
				on start
				{
					actions 
					{
					on load
					(
						if(input.status == "Overdue")
										{
											sendmail
											[
												from :zoho.loginuserid
												to :input.customer.email
												subject :"Reminder: Overdue Invoice"
												message :"<p>Dear Customer,</p><p>This is a reminder that your invoice with ID " + input.invoice_id + " is overdue. Please make the payment at your earliest convenience.</p><p>Thank you.</p>"
												content type :HTML
											]
										}
					)
					}
				}
			}
		}


