	reports
	{
		list quotes_Report
		{
			displayName = "All Quotes"
			show all rows from quotes    
			(
				quote_id as "Quote ID"
				customer as "Customer"
				service_request as "Service Request"
				service_type as "Service Type"
				status as "Status"
				subtotal as "Subtotal"
				(
					display = total,average,min,max	
				)
				tax_total as "Tax Total"
				(
					display = total,average,min,max	
				)
				grand_total as "Grand Total"
				(
					display = total,average,min,max	
				)
				books_estimate_id as "Books Estimate ID"
				last_sync_source as "Last Sync Source"
				last_sync_time as "Last Sync Time"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Declined")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Draft")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Sent")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
